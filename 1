    local sideCounts = {}
    for _, v in ipairs(visuals) do
        sideCounts[v.side] = (sideCounts[v.side] or 0) + 1
        if v.frame and v.frame.Parent then v.frame:Destroy() end
    end
    for sideName, original in pairs(baseSlotsOriginal) do
        local tlt = getTradeGUI()
        if tlt then
            local side = tlt:FindFirstChild(sideName)
            if side then
                local bs = side:FindFirstChild("BaseSlots")
                if bs then
                    bs.Text = original
                    bs.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
            end
        end
    end
    visuals = {}
    visualCount = 0
    baseSlotsOriginal = {}
end)

task.spawn(function()
    while screen and screen.Parent do
        local tlt = getTradeGUI()
        local open = tlt and tlt.Visible or false
        statusLbl.Text = open and "Trade OPEN" or "Trade CLOSED"
        statusLbl.TextColor3 = open and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 75, 75)
        task.wait(0.5)
    end
end)

local function doYourReadyAccept()
    if not exampleTradeActive then return end
    if isCooldownActive() then return end
    local bothReady = exampleState.yourReady and exampleState.otherReady
    if bothReady and not exampleState.yourAccepted then
        exampleState.yourAccepted = true
        triggerCooldown()
    elseif not bothReady and not exampleState.yourReady and #visuals > 0 then
        exampleState.yourReady = true
        triggerCooldown()
    else
        return
    end
    updateTradeButtons()
end

local function doOtherReadyAccept()
    if not exampleTradeActive then return end
    local bothReady = exampleState.yourReady and exampleState.otherReady
    if bothReady and not exampleState.otherAccepted then
        exampleState.otherAccepted = true
        triggerCooldown()
    elseif not exampleState.otherReady then
        exampleState.otherReady = true
        triggerCooldown()
    else
        return
    end
    updateTradeButtons()
end

UIS.InputBegan:Connect(function(inp, processed)
    if waitingForKeybind and inp.UserInputType == Enum.UserInputType.Keyboard then
        local which = waitingForKeybind
        waitingForKeybind = nil
        if which == "Your" then
            randConfig.keybindYour = inp.KeyCode
            keybindYourBtn.Text = "YOUR: [" .. inp.KeyCode.Name .. "]"
            keybindYourBtn.BackgroundColor3 = Color3.fromRGB(40, 30, 55)
        elseif which == "Other" then
            randConfig.keybindOther = inp.KeyCode
            keybindOtherBtn.Text = "ALLY: [" .. inp.KeyCode.Name .. "]"
            keybindOtherBtn.BackgroundColor3 = Color3.fromRGB(40, 30, 55)
        elseif which == "ReadyYour" then
            randConfig.keybindReadyYour = inp.KeyCode
            keybindReadyYourBtn.Text = "MY READY: [" .. inp.KeyCode.Name .. "]"
            keybindReadyYourBtn.BackgroundColor3 = Color3.fromRGB(30, 45, 30)
        elseif which == "ReadyOther" then
            randConfig.keybindReadyOther = inp.KeyCode
            keybindReadyOtherBtn.Text = "ALLY READY: [" .. inp.KeyCode.Name .. "]"
            keybindReadyOtherBtn.BackgroundColor3 = Color3.fromRGB(30, 45, 30)
        end
        return
    end
    if processed then return end
    if inp.KeyCode == Enum.KeyCode.RightShift then
        main.Visible = not main.Visible
    end
    if inp.KeyCode == randConfig.keybindYour then
        spawnRandomOnSide("Your")
    end
    if inp.KeyCode == randConfig.keybindOther then
        spawnRandomOnSide("Other")
    end
    if inp.KeyCode == randConfig.keybindReadyYour then
        doYourReadyAccept()
    end
    if inp.KeyCode == randConfig.keybindReadyOther then
        doOtherReadyAccept()
    end
end)

return "X Scripts SAB loaded"
