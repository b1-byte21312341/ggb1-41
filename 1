local lastChangeTime = 0
local TRADE_COOLDOWN = 5
local cooldownThread = nil
local updateCooldownTimer

local exampleTradeActive = false
local exampleConnections = {}
local exampleState = {yourReady = false, otherReady = false, yourAccepted = false, otherAccepted = false}
local closeExampleTrade

local function resetExampleState()
    exampleState = {yourReady = false, otherReady = false, yourAccepted = false, otherAccepted = false}
    for _, conn in ipairs(exampleConnections) do
        if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
    end
    exampleConnections = {}
end

local function triggerCooldown()
    lastChangeTime = tick()
    if updateCooldownTimer then updateCooldownTimer() end
end

local function isCooldownActive()
    return tick() < lastChangeTime + TRADE_COOLDOWN
end

local function updateTradeButtons()
    local tlt = pgui:FindFirstChild("TradeLiveTrade")
    if not tlt then return end
    tlt = tlt:FindFirstChild("TradeLiveTrade")
    if not tlt then return end

    local otherSide = tlt:FindFirstChild("Other")
    local yourSide = tlt:FindFirstChild("Your")
    if not otherSide or not yourSide then return end

    local readyBtn = otherSide:FindFirstChild("ReadyButton")
    local yourReadyFrame = yourSide:FindFirstChild("Ready")
    local otherReadyFrame = otherSide:FindFirstChild("Ready")
    local timerLbl = otherSide:FindFirstChild("Timer")

    local bothReady = exampleState.yourReady and exampleState.otherReady
    local bothAccepted = exampleState.yourAccepted and exampleState.otherAccepted
    local hasOffer = #visuals > 0

    if readyBtn then
        local txt = readyBtn:FindFirstChild("Txt")
        if txt then
            txt.Text = bothReady and "ACCEPT" or "READY"
        end
        local canClick = not isCooldownActive()
        if bothReady and exampleState.yourAccepted then canClick = false end
        if not bothReady and (not hasOffer or exampleState.yourReady) then canClick = false end
        readyBtn.BackgroundColor3 = canClick and Color3.fromRGB(81, 158, 86) or Color3.fromRGB(112, 112, 112)
    end

    if yourReadyFrame then
        if exampleState.yourAccepted then
            yourReadyFrame.Visible = true
            local lbl = yourReadyFrame:FindFirstChild("Label")
            if lbl then lbl.Text = "Confirmed!" end
        elseif bothReady then
            yourReadyFrame.Visible = false
        elseif exampleState.yourReady then
            yourReadyFrame.Visible = true
            local lbl = yourReadyFrame:FindFirstChild("Label")
            if lbl then lbl.Text = "Ready!" end
        else
            yourReadyFrame.Visible = false
        end
    end

    if otherReadyFrame then
        if exampleState.otherAccepted then
            otherReadyFrame.Visible = true
            local lbl = otherReadyFrame:FindFirstChild("Label")
            if lbl then lbl.Text = "Confirmed!" end
        elseif bothReady then
            otherReadyFrame.Visible = false
        elseif exampleState.otherReady then
            otherReadyFrame.Visible = true
            local lbl = otherReadyFrame:FindFirstChild("Label")
            if lbl then lbl.Text = "Ready!" end
        else
            otherReadyFrame.Visible = false
        end
    end

    if bothAccepted then
        if cooldownThread then pcall(task.cancel, cooldownThread); cooldownThread = nil end
        if timerLbl then timerLbl.Text = "Processing..." end
        if readyBtn then readyBtn.BackgroundColor3 = Color3.fromRGB(112, 112, 112) end
        task.delay(5, function()
            if exampleTradeActive then
                closeExampleTrade()
            end
        end)
    end
end

