end

saveBaseSlots = function(sideName)
    local tlt = getTradeGUI()
    if not tlt then return end
    local side = tlt:FindFirstChild(sideName)
    if not side then return end
    local bs = side:FindFirstChild("BaseSlots")
    if bs and not baseSlotsOriginal[sideName] then
        baseSlotsOriginal[sideName] = bs.Text
    end
end

updateBaseSlots = function(sideName, delta)
    local tlt = getTradeGUI()
    if not tlt then return end
    local side = tlt:FindFirstChild(sideName)
    if not side then return end
    local bs = side:FindFirstChild("BaseSlots")
    if not bs then return end

    local current, max = bs.Text:match("(%d+)/(%d+)")
    if current and max then
        local newVal = tonumber(current) + delta
        if newVal < 0 then newVal = 0 end
        bs.Text = tostring(newVal) .. "/" .. max
        if newVal > tonumber(max) then
            bs.TextColor3 = Color3.fromRGB(255, 70, 70)
        else
            bs.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end
end

spawnVisualWithParams = function(sideName, brainrotName, mutationName, traitsList)
    local scroll, tmpl = getTradeScroll(sideName)
    if not scroll or not tmpl then return end
    saveBaseSlots(sideName)

    local item = tmpl:Clone()
    item.Name = "Visual_" .. brainrotName .. "_" .. tostring(math.floor(tick() * 1000))
    item.Visible = true
    item.LayoutOrder = -900 + #visuals

    local spacer = item:FindFirstChild("Spacer")
    if not spacer then item:Destroy() return end

    local title = spacer:FindFirstChild("Title")
    if title then
        local ad = AnimalsData[brainrotName]
        title.Text = ad and ad.DisplayName or brainrotName
    end

    local mut = mutationName ~= "Normal" and mutationName or nil

    local cash = spacer:FindFirstChild("Cash")
    if cash then
        pcall(function()
            local gen = AnimalsShared:GetGeneration(brainrotName, mut, traitsList)
            if gen then
                cash.Text = "$" .. NumberUtils:ToString(gen) .. "/s"
            end
        end)
    end

    local vf = spacer:FindFirstChild("ViewportFrame")
    if vf then
        for _, c in ipairs(vf:GetChildren()) do
            if not c:IsA("UICorner") and not c:IsA("UIStroke") then c:Destroy() end
        end
        pcall(function()
            AnimalsShared:AttachOnViewportWithOptimizations(brainrotName, vf, nil, mut)
        end)

        if mut and MutationsData[mut] then
            local mutData = MutationsData[mut]
            new("ImageLabel", {
                Name = "MutationIcon",
                Size = UDim2.fromOffset(22, 22),
                Position = UDim2.new(1, -22, 1, -22),
                BackgroundColor3 = Color3.fromRGB(20, 20, 30),
                BackgroundTransparency = 0.3,
                Image = mutData.Icon or "",
                ScaleType = Enum.ScaleType.Fit,
                ZIndex = 10,
                Parent = vf
            })
            new("UICorner", {CornerRadius = UDim.new(0, 6), Parent = vf.MutationIcon})
        end
    end

    local traitsFrame = spacer:FindFirstChild("Traits")
    if traitsFrame then
        local trTmpl = traitsFrame:FindFirstChild("Template")
        if trTmpl then
            for _, trName in ipairs(traitsList) do
                local td = TraitsData[trName]
                if td then
                    local ti = trTmpl:Clone()
                    ti.Name = trName
                    ti.Visible = true
                    ti.Image = td.Icon
                    ti.Parent = traitsFrame
                end
            end
        end
    end

    local offered = false
    local stroke = spacer:FindFirstChild("UIStroke")
    spacer.BackgroundColor3 = Color3.fromRGB(35, 45, 50)
    if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end

    spacer.Activated:Connect(function()
        offered = not offered
        if offered then
            spacer.BackgroundColor3 = Color3.fromRGB(15, 50, 15)
            if stroke then stroke.Color = Color3.fromRGB(0, 255, 0) end
        else
            spacer.BackgroundColor3 = Color3.fromRGB(35, 45, 50)
            if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end
        end
    end)

    item.Parent = scroll
    table.insert(visuals, {frame = item, side = sideName, offered = false})
    visualCount = visualCount + 1
    updateBaseSlots(sideName, 1)
end

local function addVisual()
    if not sel.brainrot then return end
    local now = tick()
    if now < lastChangeTime + TRADE_COOLDOWN then return end
    local trArr = {}
    for t in pairs(sel.traits) do table.insert(trArr, t) end
    spawnVisualWithParams(sel.side, sel.brainrot, sel.mutation, trArr)
    lastChangeTime = tick()
    updateCooldownTimer()
end

