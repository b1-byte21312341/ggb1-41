local function new(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local brainrotList = {}
for name, data in pairs(AnimalsData) do
    if not name:find("Lucky Block") then
        table.insert(brainrotList, {Name = name, Rarity = data.Rarity, Display = data.DisplayName or name})
    end
end
table.sort(brainrotList, function(a, b)
    local wa = RaritiesData[a.Rarity] and RaritiesData[a.Rarity].Weight or 0
    local wb = RaritiesData[b.Rarity] and RaritiesData[b.Rarity].Weight or 0
    if wa ~= wb then return wa > wb end
    return a.Name < b.Name
end)

local mutList = {"Normal"}
for name in pairs(MutationsData) do table.insert(mutList, name) end
table.sort(mutList, function(a, b)
    if a == "Normal" then return b ~= "Normal" end
    if b == "Normal" then return false end
    return a < b
end)

