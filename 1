updateCooldownTimer = function()
    if cooldownThread then pcall(task.cancel, cooldownThread); cooldownThread = nil end
    cooldownThread = task.spawn(function()
        local tlt = getTradeGUI()
        if not tlt then return end
        local otherSide = tlt:FindFirstChild("Other")
        if not otherSide then return end
        local timerLbl = otherSide:FindFirstChild("Timer")
        local readyBtn = otherSide:FindFirstChild("ReadyButton")

        while true do
            local remaining = (lastChangeTime + TRADE_COOLDOWN) - tick()
            if remaining <= 0 then
                if timerLbl then timerLbl.Text = "" end
                if readyBtn then readyBtn.BackgroundColor3 = Color3.fromRGB(81, 158, 86) end
                if exampleTradeActive then updateTradeButtons() end
                break
            end
            local display = math.floor(remaining * 10) / 10
            if timerLbl then timerLbl.Text = string.format("\226\143\176%.1fs Left", display) end
            if readyBtn then readyBtn.BackgroundColor3 = Color3.fromRGB(112, 112, 112) end
            task.wait(0.1)
        end
    end)
end

local function spawnRandomOnSide(sideName)
    local now = tick()
    if now < lastChangeTime + TRADE_COOLDOWN then return end

    local bList = {}
    for name in pairs(randConfig.brainrots) do table.insert(bList, name) end
    if #bList == 0 then return end

    local mList = {}
    for name in pairs(randConfig.mutations) do table.insert(mList, name) end
    if #mList == 0 then table.insert(mList, "Normal") end

    local tList = {}
    for name in pairs(randConfig.traits) do table.insert(tList, name) end

    local picked = {}
    for _, t in ipairs(tList) do
        if math.random() > 0.5 then table.insert(picked, t) end
    end

    spawnVisualWithParams(sideName, bList[math.random(#bList)], mList[math.random(#mList)], picked)
    lastChangeTime = tick()
    updateCooldownTimer()
end

