local function openExampleTrade()
    local tradeScreenGui = pgui:FindFirstChild("TradeLiveTrade")
    if not tradeScreenGui then return end
    local tlt = tradeScreenGui:FindFirstChild("TradeLiveTrade")
    if not tlt then return end

    resetExampleState()

    local others = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then table.insert(others, p) end
    end
    local fakePartner = #others > 0 and others[math.random(1, #others)] or nil
    local partnerId = fakePartner and fakePartner.UserId or 1
    local partnerName = fakePartner and fakePartner.Name or "TestPlayer"

    tradeScreenGui.Enabled = true
    tlt.Visible = true
    tlt.Position = UDim2.new(0.5, 0, 0.5, 0)

    local yourSide = tlt:FindFirstChild("Your")
    if yourSide then
        local uname = yourSide:FindFirstChild("Username")
        if uname then uname.Text = "Your Offer" end
        local pimg = yourSide:FindFirstChild("PlayerImage")
        if pimg then
            local hs = pimg:FindFirstChild("Headshot")
            if hs then
                hs.Image = ("rbxthumb://type=AvatarHeadShot&id=%s&w=100&h=100"):format(player.UserId)
            end
        end
        local bs = yourSide:FindFirstChild("BaseSlots")
        if bs then bs.Text = "0/10"; bs.TextColor3 = Color3.new(1, 1, 1) end
        local r = yourSide:FindFirstChild("Ready")
        if r then r.Visible = false end
    end

    local otherSide = tlt:FindFirstChild("Other")
    if otherSide then
        local uname = otherSide:FindFirstChild("Username")
        if uname then uname.Text = ("@%s's Offer"):format(partnerName) end
        local pimg = otherSide:FindFirstChild("PlayerImage")
        if pimg then
            local hs = pimg:FindFirstChild("Headshot")
            if hs then
                hs.Image = ("rbxthumb://type=AvatarHeadShot&id=%s&w=100&h=100"):format(partnerId)
            end
        end
        local bs = otherSide:FindFirstChild("BaseSlots")
        if bs then bs.Text = "0/10"; bs.TextColor3 = Color3.new(1, 1, 1) end
        local timer = otherSide:FindFirstChild("Timer")
        if timer then timer.Text = "" end
        local ready = otherSide:FindFirstChild("Ready")
        if ready then ready.Visible = false end

        local readyButton = otherSide:FindFirstChild("ReadyButton")
        if readyButton then
            local txt = readyButton:FindFirstChild("Txt")
            if txt then txt.Text = "READY" end
            readyButton.BackgroundColor3 = Color3.fromRGB(112, 112, 112)
            table.insert(exampleConnections, readyButton.Activated:Connect(function()
                if isCooldownActive() then return end
                local bothReady = exampleState.yourReady and exampleState.otherReady
                if bothReady and not exampleState.yourAccepted then
                    exampleState.yourAccepted = true
                    triggerCooldown()
                elseif not bothReady and not exampleState.yourReady and #visuals > 0 then
                    exampleState.yourReady = true
                    triggerCooldown()
                else
                    return
                end
                updateTradeButtons()
            end))
        end

        local cancelButton = otherSide:FindFirstChild("Cancel")
        if cancelButton then
            table.insert(exampleConnections, cancelButton.Activated:Connect(function()
                closeExampleTrade()
            end))
        end
    end

    local header = tlt:FindFirstChild("Header")
    if header then
        local closeX = header:FindFirstChild("Close")
        if closeX then
            table.insert(exampleConnections, closeX.Activated:Connect(function()
                closeExampleTrade()
            end))
        end
    end

    exampleTradeActive = true
    partnerAcceptBtn.Visible = true
    exampleBtn.Text = "CLOSE EXAMPLE TRADE"
    exampleBtn.BackgroundColor3 = Color3.fromRGB(130, 60, 30)
    updateTradeButtons()
end

closeExampleTrade = function()
    local tradeScreenGui = pgui:FindFirstChild("TradeLiveTrade")
    if not tradeScreenGui then return end
    local tlt = tradeScreenGui:FindFirstChild("TradeLiveTrade")
    if not tlt then return end

    resetExampleState()
    lastChangeTime = 0
    if cooldownThread then pcall(task.cancel, cooldownThread); cooldownThread = nil end

    for _, v in ipairs(visuals) do
        if v.frame and v.frame.Parent then v.frame:Destroy() end
    end
    visuals = {}
    visualCount = 0
